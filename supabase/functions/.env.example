# Gemini API key — get from Google AI Studio (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# ── Email (production) ──────────────────────────────────────────────
# Resend API key — get from https://resend.com/api-keys
# If not set, emails are sent to the local Inbucket SMTP (dev mode).
RESEND_API_KEY=re_xxxxxxxxxxxx

# "From" address shown in emails.
# For Resend: must use a verified domain (e.g. noreply@yourdomain.com)
# or "AlignerTrack <noreply@yourdomain.com>".
EMAIL_FROM=AlignerTrack <noreply@yourdomain.com>

# Public URL of the app (used in email links).
APP_URL=https://yourdomain.com
